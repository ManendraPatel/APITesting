{
  "info": {
    "_postman_id": "ca2da2a9-37b8-4922-8dce-4b81b38a90f6",
    "name": "API Chaining Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "33334349",
