    {
      "name": "Update Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Response body contains 'name' field matching request\", function () {",
              "    var jsonData = pm.response.json();",
              "    var requestBody = JSON.parse(pm.request.body.raw);",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "    pm.expect(jsonData.name).to.eql(requestBody.name);",
              "});",
              "",
              "pm.test(\"Response body contains 'job' field matching request\", function () {",
              "    var jsonData = pm.response.json();",
              "    var requestBody = JSON.parse(pm.request.body.raw);",
              "    pm.expect(jsonData).to.have.property(\"job\");",
              "    pm.expect(jsonData.job).to.eql(requestBody.job);",
              "});",
              "",
              "pm.test(\"Response body contains 'updatedAt' field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"updatedAt\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
