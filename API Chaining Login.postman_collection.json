  "item": [
    {
      "name": "Login {Extract Token}",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login successful - Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is generated\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"token\");\r",
              "    pm.expect(jsonData.token).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// Save token to environment variable\r",
              "var jsonData = pm.response.json();\r",
              "if (jsonData.token) {\r",
              "    pm.environment.set(\"token\", jsonData.token);\r",
              "    console.log(\"Token saved to environment: \" + jsonData.token);}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"runStartTime\", new Date().toISOString());\r",
              "console.log(\"Run started at:\", pm.environment.get(\"runStartTime\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "pro_15ff032585a61965c4ff87b2925703a14c0bac9c674343d8f302e6ff8341c4ba",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"eve.holt@reqres.in\",\r\n    \"password\": \"cityslicka\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{reqURL}}/api/login",
          "host": [
            "{{reqURL}}"
          ],
          "path": [
            "api",
            "login"
          ]
        },
        "description": "create login APi and extract token"
      },
      "response": []
    },
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"User created successfully - Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response body contains 'id' field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Response body contains 'createdAt' field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"createdAt\");",
              "});",
              "",
              "// Save user ID to environment variable",
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData.id) {",
              "    pm.environment.set(\"userId\", jsonData.id);",
              "    console.log(\"userId saved to environment:\", jsonData.id);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "pro_15ff032585a61965c4ff87b2925703a14c0bac9c674343d8f302e6ff8341c4ba",
            "type": "text"
          }
        ],
        "body": {
